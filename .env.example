# ── Supabase (shared project with lyrise/website) ────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── ROI Pipeline ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=
TAVILY_API_KEY=
BRAVE_API_KEY=          # optional — fallback web search (2k free/month)

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=             # e.g. reports@roi.lyrise.ai (defaults to this if unset)

# ── OAuth (Google) ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Webhooks ──────────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=
N8N_FEEDBACK_WEBHOOK_URL=

# ── App URL (used for share links, email links, usage alerts) ─────────────────
NEXT_PUBLIC_BASE_URL=   # e.g. https://roi.lyrise.ai in prod, http://localhost:3000 in dev

# ── Analytics / env ───────────────────────────────────────────────────────────
NEXT_PUBLIC_ENV=production
NEXT_PUBLIC_AMPLITUDE=

# ── Usage alerts (prod only — leave blank in dev) ─────────────────────────────
ROI_USAGE_ALERT_EMAILS=
# ROI_USAGE_ALERT_THRESHOLD_USD=10
# ROI_USAGE_ALERT_WINDOW_DAYS=30
# ROI_USAGE_ALERTS_IN_DEV=true

# ── Dev/debug ─────────────────────────────────────────────────────────────────
# DEV_ALERT_EMAILS=
# ROI_DEBUG=true
# NEXT_PUBLIC_ROI_MIN_LOADER_MS=3500
